{
  "expo": {
    "name": "BudgetTracko",
    "slug": "budgettracko",
    "version": "2.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo512.png",
    "scheme": "budgettracko",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0A0A",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/logo512.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": true,
      "backgroundColor": "#0A0A0A",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Allow BudgetTracko to authenticate you using Face ID."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo512.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.budgettracko.app",
      "backgroundColor": "#0A0A0A",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo512.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow BudgetTracko to use your camera to scan bills."
        }
      ],
      [
        "expo-quick-actions",
        {
          "androidIcons": {
            "add_expense": {
              "foregroundImage": "./assets/images/logo512.png"
            },
            "add_income": {
              "foregroundImage": "./assets/images/logo512.png"
            }
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6c69b101-a38b-47fc-a2bf-1be0432c8d0f"
      }
    },
    "owner": "bhargavk001"
  }
}
