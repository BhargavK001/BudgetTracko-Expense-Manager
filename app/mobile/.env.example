# Mobile app environment variables
# Copy this file to `.env` in app/mobile and set values for your machine.

# Backend API base URL used by the mobile app.
# Preferred variable for Expo projects:
# EXPO_PUBLIC_BACKEND_URL
#
# Backward-compatible aliases supported by the app:
# - BACKEND_URL
# - EXPO_PUBLIC_API_URL
#
# Development guidance:
# Use your local network IP when testing on a physical device.
# Examples:
# - Android emulator: http://10.0.2.2:5000
# - iOS simulator: http://localhost:5000
# - Physical device: http://192.168.1.25:5000
EXPO_PUBLIC_BACKEND_URL=http://10.0.2.2:5000

# Temporary testing switch:
# Set to true to force AWS backend even in development mode.
# Set to false (or remove) to return to local/dev URL logic.
EXPO_PUBLIC_FORCE_AWS_BACKEND=true
